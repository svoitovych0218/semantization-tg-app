# PostgreSQL connection (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://semantle:semantle@postgres:5432/semantle

# Telegram bot token from @BotFather
BOT_TOKEN=your-telegram-bot-token-here

# Public HTTPS base URL where this server is reachable (no trailing slash)
# Telegram will POST updates to ${WEBHOOK_URL}/webhook/${BOT_TOKEN}
WEBHOOK_URL=https://your-domain.com

# Secret key for the admin API (x-key header)
ADMIN_KEY=your-secret-admin-key-here

# Public URL of the Mini App (Cloudflare Pages or ngrok in local dev)
MINI_APP_URL=https://your-mini-app.pages.dev

# PostgreSQL container credentials (used by docker-compose postgres service)
POSTGRES_USER=semantle
POSTGRES_PASSWORD=semantle
POSTGRES_DB=semantle
